# EvalHire Engine — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# GitHub Models (or any OpenAI-spec provider) API token
MODEL_TOKEN=ghp_your_github_models_token_here

# API key to protect the /evaluate endpoint
# Leave unset to disable auth (development / local mode only)
API_KEY=your_api_key_here

# Secret used to sign JWT tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Auto-generated at startup if unset — set a stable value for production so tokens survive restarts.
SECRET_KEY=your_secret_key_here

# Database URL (SQLite for local, PostgreSQL for production)
# Railway provides DATABASE_URL automatically for PostgreSQL add-ons.
# postgres:// URLs are auto-converted to postgresql:// at startup.
DATABASE_URL=sqlite:///./evalhire.db
